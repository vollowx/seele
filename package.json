{
  "name": "@vollowx/seele",
  "version": "0.12.9",
  "description": "A extensible Web Components library, with Material Design 3 components pre-provided.",
  "author": "vollowx",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/all.js",
  "module": "./src/all.js",
  "exports": {
    ".": "./src/all.js",
    "./base/*": "./src/base/*",
    "./m3/*": "./src/m3/*"
  },
  "files": [
    "src/**/*.js",
    "src/m3/system/*.css",
    "custom-elements.json",
    "LICENSE",
    "README.md"
  ],
  "customElements": "custom-elements.json",
  "keywords": [
    "web-components",
    "material-design",
    "material-3",
    "lit",
    "ui-components"
  ],
  "homepage": "https://tideover.cc/seele/",
  "repository": {
    "type": "git",
    "url": "https://github.com/vollowx/seele.git"
  },
  "scripts": {
    "dev": "wds",
    "dev:styles": "bun scripts/build-styles.ts --watch",
    "build": "bun run build:styles && bun run build:compile",
    "build:compile": "bun scripts/build.ts",
    "build:styles": "bun scripts/build-styles.ts --minify",
    "clean": "./scripts/clean.sh",
    "prepublishOnly": "bun clean && bun run build",
    "format": "prettier . --check",
    "format:write": "prettier . --check --write",
    "cem": "cem analyze --litelement --globs './src/m3/**/*.ts' --exclude './src/**/*.css.ts'"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@swc/core": "^1.15.43",
    "@types/bun": "^1.3.14",
    "@web/dev-server": "^0.4.6",
    "@web/dev-server-esbuild": "^1.0.5",
    "chokidar": "^5.0.0",
    "lightningcss": "^1.32.0",
    "prettier": "^3.9.1"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@swc/helpers": "^0.5.23",
    "lit": "^3.3.3"
  }
}
